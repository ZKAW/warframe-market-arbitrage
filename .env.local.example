# Port the dashboard itself listens on (the Next.js dev/start server).
PORT=3000

# All optional - sensible defaults are baked in if you skip this file
# entirely. Copy to .env.local and adjust as needed.

# Delay after each successful warframe.market request, in seconds
REQUEST_DELAY=0.75

# How long to back off after a 429 (rate limited), in seconds
RATE_LIMIT_DELAY=1.5

# How often to re-scan the full market, in seconds
RETRY_INTERVAL=600

# Arbitrage tab: minimum platinum profit to show a set
MIN_ARBITRAGE_VALUE=15

# Arbitrage tab: minimum 48h closed-trade volume for a set to show.
# Filters out "profitable" sets nobody actually trades. Default: 2
MIN_VOLUME=2

# Ducats tab: minimum ducat-per-platinum ratio and minimum ducat value
# to show an item
MIN_DUCAT_PER_PLATINUM=20
MIN_DUCATS=15

# How old an entry can get before it's hidden from the UI, in seconds
MAX_DATA_AGE_SECONDS=900
