# Port the dashboard itself listens on (the Next.js dev/start server).
PORT=3000

# All optional - sensible defaults are baked in if you skip this file
# entirely. Copy to .env.local and adjust as needed.

# --- Rate limiting (the only knob you usually tune) ---

# Hard cap on simultaneous in-flight warframe.market fetches, process-wide.
# Every loop (catalog build, arbitrage sweep, ducats sweep) funnels through
# one semaphore sized to this. The catalog + hot worker pools can never stack
# beyond this many concurrent downstream requests. Default 2 stays under
# warframe.market's measured rate ceiling; raise cautiously - too high and
# every fetch starts returning 429 and the loop stalls on 10s backoffs.
MAX_CONCURRENT_REQUESTS=2

# Delay after each successful request, seconds. This is the sustained-rate
# gate (maxConcurrentRequests caps the burst). 0.75s × maxConcurrentRequests
# is your effective sustained req/s.
REQUEST_DELAY=0.75

# How long to back off after a 429, seconds. Should be long enough that the
# API's quota window resets; if you're seeing many 429s raise this or lower
# MAX_CONCURRENT_REQUESTS.
RATE_LIMIT_DELAY=1.5

# --- Hot loops (price/volume sweeps) ---

# Time between price/volume sweeps, seconds. Each hot tick walks every set
# (arbitrage) and every prime item (ducats), ordering the sweep by
# last_updated ASC so stale rows get re-fetched before fresh ones.
HOT_RETRY_INTERVAL=120

# Max sets / prime items processed in parallel within ONE hot sweep. With the
# global MAX_CONCURRENT_REQUESTS cap in place this only splits the per-sweep
# budget across workers; raising past the global cap no longer increases real
# concurrency. Lower it if a single sweep should yield to the catalog build;
# raise to MAX_CONCURRENT_REQUESTS to give one sweep the full budget.
HOT_CONCURRENCY=2

# --- Catalog (cold) loop ---

# Max sets/prime items built in parallel during a cold catalog rebuild.
# Same stacking rules as HOT_CONCURRENCY: bounded by MAX_CONCURRENT_REQUESTS.
# Lower this if the catalog build is starving the hot sweeps of in-flight
# slots; raise to MAX_CONCURRENT_REQUESTS to let the build finish faster
# (the hot sweeps will wait for slots during the build).
CATALOG_CONCURRENCY=2

# Time between full catalog rebuilds, seconds. The catalog (set->parts map,
# prime->ducats map) is rebuilt at this cadence by the cold loop, separate
# from the hot price sweeps. Default 6h.
CATALOG_REFRESH_SECONDS=21600

# Cold loop retry interval while no catalog has ever been built, seconds.
# Once a build has successfully produced a catalog, CATALOG_REFRESH_SECONDS
# takes over; until then the cold loop retries on this short cadence so a
# flaky first build self-corrects in seconds instead of sitting idle.
COLD_RETRY_SECONDS=30

# --- Arbitrage filter ---

# Minimum platinum profit to show a set
MIN_ARBITRAGE_VALUE=15

# Minimum 48h closed-trade volume for a set to show. Filters out "profitable"
# sets nobody actually trades.
MIN_VOLUME=2

# --- Ducats filter ---

# Minimum ducat-per-platinum ratio and minimum ducat value to show an item
MIN_DUCAT_PER_PLATINUM=20
MIN_DUCATS=15
