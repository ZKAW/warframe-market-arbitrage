# Copy to config.yaml and adjust. PORT lives in .env.local.

filters:
  # Arbitrage: minimum platinum profit to show a set.
  minArbitrageValue: 15
  # Arbitrage: minimum 48h closed-trade volume for a set to show.
  minVolume: 2
  # Ducats: minimum ducat-per-platinum ratio to show an item.
  minDucatPerPlatinum: 20
  # Ducats: minimum ducat value to show an item.
  minDucats: 15

rateLimit:
  # Process-wide cap on simultaneous in-flight warframe.market fetches (burst).
  maxConcurrentRequests: 6
  # Delay after each successful request, seconds (sustained-rate gate).
  requestDelay: 1.5
  # Backoff after a 429, seconds.
  rateLimitDelay: 1.5

hot:
  # Time between price/volume sweeps, seconds (staleness budget).
  hotRetryInterval: 120
  # Max sets/prime items processed in parallel within one hot sweep.
  hotConcurrency: 4

catalog:
  # Max sets/prime items built in parallel during a cold catalog rebuild.
  catalogConcurrency: 2
  # Time between full catalog rebuilds, seconds (default 6h).
  catalogRefreshSeconds: 21600
  # Cold loop retry interval while no catalog has ever been built, seconds.
  coldRetrySeconds: 30
